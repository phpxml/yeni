import requests
import re
import os

def get_stream():
    url = "https://www.atv.com.tr/atv-avrupa/canli-yayin"
    headers = {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/120.0.0.0"}
    
    try:
        r = requests.get(url, headers=headers, timeout=10)
        # Regex to find the tokenized m3u8 link
        match = re.search(r'(https://[^\s"]+\.m3u8\?st=[^"&]+&e=[0-9]+)', r.text)
        
        if match:
            link = match.group(1).replace("\\/", "/")
            
            # Go up two levels to reach the root directory (tur -> ressources -> root)
            current_dir = os.path.dirname(os.path.abspath(__file__))
            root_dir = os.path.join(current_dir, "..", "..")
            file_path = os.path.join(root_dir, "atv_avrupa.m3u")
            
            with open(file_path, "w", encoding="utf-8") as f:
                f.write(f"#EXTM3U\n#EXTINF:-1,atv Avrupa\n{link}")
            print(f"Success: File created at {file_path}")
        else:
            print("Error: Link not found in page source.")
    except Exception as e:
        print(f"System Error: {e}")

if __name__ == "__main__":
    get_stream()
