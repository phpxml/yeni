import requests
import re
import os

def get_token_link():
    # IDM gibi resmi siteye istek atıyoruz
    target_url = "https://www.atv.com.tr/atv-avrupa/canli-yayin"
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/120.0.0.0 Safari/537.36",
        "Referer": "https://www.atv.com.tr/"
    }

    try:
        response = requests.get(target_url, headers=headers, timeout=15)
        # Kaynak kodun içindeki m3u8?st=...&e=... yapısını yakalayan regex
        pattern = r'(https://[^\s"]+\.m3u8\?st=[^"&]+&e=[0-9]+)'
        match = re.search(pattern, response.text)

        if match:
            # Yakalanan linkteki ters bölü işaretlerini temizle
            raw_link = match.group(1).replace("\\/", "/")
            return raw_link
    except Exception as e:
        print(f"Hata olustu: {e}")
    return None

def create_m3u(link):
    if link:
        # M3U dosyasını ana dizine (root) çıkartıyoruz
        with open("atv_avrupa.m3u", "w", encoding="utf-8") as f:
            f.write("#EXTM3U\n")
            f.write("#EXTINF:-1,atv Avrupa (Auto-Update)\n")
            f.write(f"{link}\n")
        print("M3U dosyasi basariyla olusturuldu.")
    else:
        print("Link bulunamadigi icin dosya guncellenmedi.")

if __name__ == "__main__":
    taze_link = get_token_link()
    create_m3u(taze_link)
